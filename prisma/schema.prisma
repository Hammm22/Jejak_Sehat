generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Catatan {
  id_catatan  Int      @id @default(autoincrement()) @map("id_catatan")
  nik         Int      @map("nik")
  nama_tempat String   @map("nama_tempat")
  tanggal     DateTime @map("tanggal")
  waktu       DateTime @map("waktu")
  lokasi      String   @map("lokasi")
  suhu        Int      @map("suhu")

  user User @relation(fields: [nik], references: [nik])

  @@map("Catatan")
}
  
model User {
  nik      Int    @id @map("nik")
  nama     String @map("nama")
  password String @map("password")
  profil   String? @map("profil")

  catatan  Catatan[]

  @@map("User")
}